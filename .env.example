# Per lo sviluppo locale usare esclusivamente il progetto Supabase di staging.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# URL pubblico dell'applicazione; in locale lasciare questo valore.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Solo server: non aggiungere mai il prefisso NEXT_PUBLIC_.
# Usata per inviti Auth e lettura email utenti, esclusivamente server-side.
SUPABASE_SECRET_KEY=

# Solo Staging: email reale facoltativa per il collaudo dei messaggi Auth.
DEMO_ADMIN_EMAIL=

# Solo Staging: password iniziale condivisa dai quattro utenti dimostrativi.
# Usare almeno 12 caratteri e non salvare mai il valore nel repository.
DEMO_PASSWORD=
